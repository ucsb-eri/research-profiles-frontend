# Copy to .env.local to override the API base URL for your own machine.
# NEXT_PUBLIC_* vars are exposed to the browser and baked in at build time.
#
# Defaults (no setup needed):
#   next dev             -> .env.development (http://localhost:3001)
#   next build / start   -> .env.production  (https://api.research-profiles.grit.ucsb.edu)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Google OAuth Web client ID (for owner login with a @ucsb.edu account).
# Create one in Google Cloud Console -> Credentials -> OAuth client ID (Web),
# with authorized JS origin + redirect http://localhost:3000/auth/callback
# (and your production origin). No client secret is needed (implicit flow).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
